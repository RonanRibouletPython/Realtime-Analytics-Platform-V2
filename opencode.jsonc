{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "llama.cpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama-server (local)",
            "options": {
                "baseURL": "http://host.docker.internal:11434/v1",
                "apiKey": "none"
            },
            "models": {
                "local-model": {
                    "name": "local-model",
                    "limit": {
                        "context": 65536,
                        "output": 3072
                    }
                }
            }
        }
    }
}